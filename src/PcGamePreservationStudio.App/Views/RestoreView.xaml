<UserControl x:Class="PcGamePreservationStudio.App.Views.RestoreView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="720" HorizontalAlignment="Left">
            <TextBlock Text="Restore" Style="{StaticResource HeadingTextStyle}" />
            <TextBlock TextWrapping="Wrap" Style="{StaticResource SecondaryTextStyle}" Margin="0,0,0,12"
                       Text="Restores an archive back to disk. This always re-verifies every file against its recorded checksums first and never touches anything if that fails." />

            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}" TextWrapping="Wrap"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}" Margin="0,0,0,12" />

            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Archive to restore" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="Browse…" Margin="8,0,0,0" Command="{Binding BrowseArchiveSourceCommand}" />
                        <TextBox Text="{Binding ArchiveSourcePath}" IsReadOnly="True" />
                    </DockPanel>
                    <TextBlock Text="Reading archive…" Style="{StaticResource SecondaryTextStyle}" Margin="0,8,0,0"
                               Visibility="{Binding IsLoadingPreflight, Converter={StaticResource BoolToVisibilityConverter}}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16"
                    Visibility="{Binding Preflight, Converter={StaticResource NullToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="{Binding Preflight.Manifest.Title, StringFormat='Archive: {0}'}" FontWeight="SemiBold" Margin="0,0,0,4" TextWrapping="Wrap" />
                    <TextBlock Style="{StaticResource SecondaryTextStyle}" Margin="0,0,0,8">
                        <Run Text="{Binding Preflight.Manifest.Platform, Mode=OneWay}" />
                        <Run Text=" · App ID " />
                        <Run Text="{Binding Preflight.Manifest.AppId, Mode=OneWay}" />
                        <Run Text=" · Preservation rating: " />
                        <Run Text="{Binding Preflight.Manifest.PreservationRating, Mode=OneWay}" />
                    </TextBlock>
                    <TextBlock Text="{Binding Preflight.Manifest.RequiredAccountNotice}" TextWrapping="Wrap" Style="{StaticResource SecondaryTextStyle}" Margin="0,0,0,8" />
                    <TextBlock TextWrapping="Wrap" Style="{StaticResource SecondaryTextStyle}">
                        <Run Text="Contains: " />
                        <Run Text="{Binding Preflight.HasGameFiles, Mode=OneWay, StringFormat='Game files: {0}'}" />
                        <Run Text=" · " />
                        <Run Text="{Binding Preflight.HasInstallerFiles, Mode=OneWay, StringFormat='Installers: {0}'}" />
                        <Run Text=" · " />
                        <Run Text="{Binding Preflight.HasPlatformFiles, Mode=OneWay, StringFormat='Platform files: {0}'}" />
                        <Run Text=" · " />
                        <Run Text="{Binding SaveLocationOptions.Count, Mode=OneWay, StringFormat='Save location(s): {0}'}" />
                    </TextBlock>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16"
                    Visibility="{Binding Preflight, Converter={StaticResource NullToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="Restore game files to" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="Browse…" Margin="8,0,0,0" Command="{Binding BrowseInstallDestinationCommand}" />
                        <TextBox Text="{Binding InstallDestinationPath, UpdateSourceTrigger=PropertyChanged}" />
                    </DockPanel>
                    <CheckBox Content="Overwrite existing files at the destination" IsChecked="{Binding OverwriteExistingFiles}" Margin="0,8,0,0" />
                    <TextBlock TextWrapping="Wrap" Style="{StaticResource SecondaryTextStyle}" Margin="0,4,0,0"
                               Text="When unchecked, files that already exist at the destination are left alone and listed after restoring instead of being overwritten." />
                </StackPanel>
            </Border>

            <Border Margin="0,0,0,16">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SaveLocationOptions.Count}" Value="0">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <TextBlock Text="Save locations" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <TextBlock TextWrapping="Wrap" Style="{StaticResource SecondaryTextStyle}" Margin="0,0,0,10"
                               Text="Each will be restored to the path shown — edit it if you want it to land somewhere else." />
                    <ItemsControl ItemsSource="{Binding SaveLocationOptions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource BorderBrush2}" BorderThickness="0,0,0,1" Padding="0,8">
                                    <StackPanel>
                                        <CheckBox IsChecked="{Binding IsIncluded}" Content="{Binding ArchiveFolderName}" FontWeight="SemiBold" />
                                        <TextBlock Style="{StaticResource SecondaryTextStyle}" Margin="0,2,0,4">
                                            <Run Text="{Binding Kind, Mode=OneWay}" />
                                            <Run Text=" · " />
                                            <Run Text="{Binding Confidence, Mode=OneWay}" />
                                            <Run Text=" confidence" />
                                        </TextBlock>
                                        <TextBox Text="{Binding RestoreToPath, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <Button Content="Restore" Style="{StaticResource AccentButtonStyle}" MinWidth="120" Command="{Binding RestoreCommand}" />
                <TextBlock Text="{Binding ProgressText}" VerticalAlignment="Center" Margin="12,0,0,0"
                           Style="{StaticResource SecondaryTextStyle}"
                           Visibility="{Binding ProgressText, Converter={StaticResource StringToVisibilityConverter}}" />
            </StackPanel>

            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16"
                    Visibility="{Binding RestoreResult, Converter={StaticResource NullToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold" Margin="0,0,0,4">
                        <Run Text="Restore: " />
                        <Run Text="{Binding RestoreResult.Success, Mode=OneWay}" />
                    </TextBlock>
                    <TextBlock Style="{StaticResource SecondaryTextStyle}" Margin="0,0,0,4"
                               Visibility="{Binding RestoreResult.VerificationResult, Converter={StaticResource NullToVisibilityConverter}}">
                        <Run Text="Verification: " />
                        <Run Text="{Binding RestoreResult.VerificationResult.Outcome, Mode=OneWay}" />
                    </TextBlock>
                    <TextBlock Style="{StaticResource SecondaryTextStyle}" Margin="0,0,0,4">
                        <Run Text="{Binding RestoreResult.FilesRestored, Mode=OneWay}" />
                        <Run Text=" file(s) restored, " />
                        <Run Text="{Binding RestoreResult.SkippedExistingFiles.Count, Mode=OneWay}" />
                        <Run Text=" skipped (already existed)" />
                    </TextBlock>
                    <ItemsControl ItemsSource="{Binding RestoreResult.Notes}" Margin="0,4,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding StringFormat='- {0}'}" Style="{StaticResource SecondaryTextStyle}" TextWrapping="Wrap" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
