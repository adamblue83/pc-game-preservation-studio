<Application x:Class="PcGamePreservationStudio.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PcGamePreservationStudio.App"
             xmlns:vm="clr-namespace:PcGamePreservationStudio.App.ViewModels"
             xmlns:views="clr-namespace:PcGamePreservationStudio.App.Views"
             xmlns:conv="clr-namespace:PcGamePreservationStudio.App.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/DarkTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <conv:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
            <conv:EnumMatchToBooleanConverter x:Key="EnumMatchToBooleanConverter" />
            <conv:InverseBooleanConverter x:Key="InverseBooleanConverter" />
            <conv:BytesToFriendlySizeConverter x:Key="BytesToFriendlySizeConverter" />
            <conv:GamePlatformToLabelConverter x:Key="GamePlatformToLabelConverter" />
            <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
            <conv:FitsOnSingleMediumToTextConverter x:Key="FitsOnSingleMediumToTextConverter" />
            <conv:DrmAnalysisLabelToTextConverter x:Key="DrmAnalysisLabelToTextConverter" />
            <conv:DrmAnalysisConfidenceToTextConverter x:Key="DrmAnalysisConfidenceToTextConverter" />

            <DataTemplate DataType="{x:Type vm:LibraryViewModel}">
                <views:LibraryView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:GameDetailViewModel}">
                <views:GameDetailView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:CreateArchiveViewModel}">
                <views:CreateArchiveView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:GogInstallerArchiveViewModel}">
                <views:GogInstallerArchiveView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ArchivesViewModel}">
                <views:ArchivesView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:BurnDiscViewModel}">
                <views:BurnDiscView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:VerifyDiscViewModel}">
                <views:VerifyDiscView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:RestoreViewModel}">
                <views:RestoreView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                <views:SettingsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:AboutViewModel}">
                <views:AboutView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ComingSoonViewModel}">
                <views:ComingSoonView />
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
